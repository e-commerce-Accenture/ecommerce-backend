    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "dev": "node --watch src/server.js",
    "test": "vitest"
  },
  "engines": {
    "node": "22"
  },
  "main": "index.js",
  "dependencies": {
    "@google/genai": "^2.9.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "firebase-admin": "^13.10.0",
    "firebase-functions": "^7.2.5",
    "jsonwebtoken": "^9.0.3",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "firebase-functions-test": "^3.4.1",
    "vitest": "^4.1.9"
  },
  "private": true
